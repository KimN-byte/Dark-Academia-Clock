<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Clock</title>
<link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

body {
  background: #13100d;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Cormorant Garamond', Georgia, serif;
  overflow: hidden;
}

.grain {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 20;
  opacity: 0.35;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.1'/%3E%3C/svg%3E");
}

.wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.8rem;
  position: relative;
  z-index: 2;
  padding: 1.5rem;
}

.clock-outer {
  position: relative;
  width: 220px;
  height: 220px;
}

/* Outer ornamental ring */
.clock-outer::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    #3a2e1e 0deg, #6b4f2a 10deg, #3a2e1e 20deg,
    #6b4f2a 30deg, #3a2e1e 40deg, #6b4f2a 50deg,
    #3a2e1e 60deg, #6b4f2a 70deg, #3a2e1e 80deg,
    #6b4f2a 90deg, #3a2e1e 100deg, #6b4f2a 110deg,
    #3a2e1e 120deg, #6b4f2a 130deg, #3a2e1e 140deg,
    #6b4f2a 150deg, #3a2e1e 160deg, #6b4f2a 170deg,
    #3a2e1e 180deg, #6b4f2a 190deg, #3a2e1e 200deg,
    #6b4f2a 210deg, #3a2e1e 220deg, #6b4f2a 230deg,
    #3a2e1e 240deg, #6b4f2a 250deg, #3a2e1e 260deg,
    #6b4f2a 270deg, #3a2e1e 280deg, #6b4f2a 290deg,
    #3a2e1e 300deg, #6b4f2a 310deg, #3a2e1e 320deg,
    #6b4f2a 330deg, #3a2e1e 340deg, #6b4f2a 350deg,
    #3a2e1e 360deg
  );
  box-shadow: 0 0 0 2px #8b6914, inset 0 0 0 2px #8b6914;
}

/* Inner clock face */
.clock-face {
  position: absolute;
  inset: 10px;
  border-radius: 50%;
  background: radial-gradient(ellipse at 35% 30%, #2a2018 0%, #1a1410 50%, #0f0c09 100%);
  border: 1.5px solid #5a4520;
  overflow: hidden;
}

.clock-face::before {
  content: '';
  position: absolute;
  inset: 6px;
  border-radius: 50%;
  border: 0.5px solid #3a2e1e;
}

/* Tick marks */
.ticks {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.tick {
  position: absolute;
  top: 50%;
  left: 50%;
  transform-origin: 0 0;
  background: #6b4f2a;
}

/* Roman numerals via SVG */
.clock-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* Hands */
.hands {
  position: absolute;
  inset: 0;
  border-radius: 50%;
}

.hand {
  position: absolute;
  bottom: 50%;
  left: 50%;
  transform-origin: bottom center;
  border-radius: 4px 4px 2px 2px;
}

.hand-hour {
  width: 3px;
  height: 56px;
  margin-left: -1.5px;
  background: linear-gradient(to top, #c9a96e, #e8d5b7);
  border-radius: 3px 3px 1px 1px;
  filter: drop-shadow(0 0 3px rgba(200, 160, 80, 0.4));
}

.hand-minute {
  width: 2px;
  height: 72px;
  margin-left: -1px;
  background: linear-gradient(to top, #a07840, #d4b896);
  border-radius: 2px 2px 1px 1px;
  filter: drop-shadow(0 0 2px rgba(200, 160, 80, 0.3));
}

.hand-second {
  width: 1px;
  height: 76px;
  margin-left: -0.5px;
  background: linear-gradient(to top, #8b2020, #c0392b);
  border-radius: 1px;
  filter: drop-shadow(0 0 2px rgba(180, 40, 40, 0.5));
}

.hand-second::after {
  content: '';
  position: absolute;
  bottom: -12px;
  left: -2px;
  width: 5px;
  height: 14px;
  background: #c0392b;
  border-radius: 2px;
}

/* Center cap */
.center-cap {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: radial-gradient(circle, #e8d5b7, #8b6914);
  border: 1px solid #6b4f2a;
  z-index: 10;
}

/* Digital readout */
.digital {
  font-family: 'IM Fell English', Georgia, serif;
  font-style: italic;
  color: #c9a96e;
  font-size: 1.05rem;
  letter-spacing: 0.12em;
  text-align: center;
  opacity: 0.9;
}

.date-line {
  font-family: 'Cormorant Garamond', Georgia, serif;
  color: #6b4f2a;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-align: center;
}

.ornament {
  color: #8b6914;
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  opacity: 0.6;
}
</style>
</head>
<body>
<div class="grain"></div>
<div class="wrapper">
  <div class="ornament">✦ ✦ ✦</div>

  <div class="clock-outer">
    <div class="clock-face">
      <!-- SVG for roman numerals and tick marks -->
      <svg class="clock-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <!-- Minute tick marks -->
        <g stroke="#3a2e1e" stroke-width="1">
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(6 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(12 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(18 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(24 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(36 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(42 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(48 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(54 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(66 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(72 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(78 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(84 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(96 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(102 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(108 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(114 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(126 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(132 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(138 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(144 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(156 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(162 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(168 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(174 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(186 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(192 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(198 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(204 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(216 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(222 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(228 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(234 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(246 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(252 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(258 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(264 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(276 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(282 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(288 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(294 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(306 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(312 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(318 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(324 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(336 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(342 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(348 100 100)"/>
          <line x1="100" y1="12" x2="100" y2="18" transform="rotate(354 100 100)"/>
        </g>
        <!-- Hour tick marks (longer) -->
        <g stroke="#6b4f2a" stroke-width="1.5">
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(0 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(30 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(60 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(90 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(120 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(150 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(180 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(210 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(240 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(270 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(300 100 100)"/>
          <line x1="100" y1="10" x2="100" y2="22" transform="rotate(330 100 100)"/>
        </g>
        <!-- Roman numerals -->
        <g font-family="'IM Fell English', Georgia, serif" font-style="italic" fill="#c9a96e" font-size="11" text-anchor="middle" dominant-baseline="middle">
          <text x="100" y="30">XII</text>
          <text x="148" y="43">I</text>
          <text x="170" y="78">II</text>
          <text x="176" y="100">III</text>
          <text x="170" y="123">IV</text>
          <text x="148" y="158">V</text>
          <text x="100" y="172">VI</text>
          <text x="52" y="158">VII</text>
          <text x="30" y="123">VIII</text>
          <text x="24" y="100">IX</text>
          <text x="30" y="78">X</text>
          <text x="52" y="43">XI</text>
        </g>
        <!-- Subtle inner decoration ring -->
        <circle cx="100" cy="100" r="30" fill="none" stroke="#2a2018" stroke-width="0.5"/>
      </svg>

      <!-- Clock hands -->
      <div class="hands">
        <div class="hand hand-hour" id="hour"></div>
        <div class="hand hand-minute" id="minute"></div>
        <div class="hand hand-second" id="second"></div>
      </div>
      <div class="center-cap"></div>
    </div>
  </div>

  <div class="digital" id="digital">--:-- --</div>
  <div class="date-line" id="dateline">— · —</div>
  <div class="ornament">✦ ✦ ✦</div>
</div>

<script>
const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];

function tick() {
  // Central Time (America/Chicago)
  const now = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Chicago' }));

  const h = now.getHours();
  const m = now.getMinutes();
  const s = now.getSeconds();

  const hDeg = (h % 12) * 30 + m * 0.5 + s * (0.5/60);
  const mDeg = m * 6 + s * 0.1;
  const sDeg = s * 6;

  document.getElementById('hour').style.transform = `rotate(${hDeg}deg)`;
  document.getElementById('minute').style.transform = `rotate(${mDeg}deg)`;
  document.getElementById('second').style.transform = `rotate(${sDeg}deg)`;

  // Digital readout
  const hh = h % 12 || 12;
  const mm = String(m).padStart(2, '0');
  const ampm = h < 12 ? 'AM' : 'PM';
  document.getElementById('digital').textContent = `${hh}:${mm} ${ampm}`;

  // Date line
  const day = days[now.getDay()];
  const month = months[now.getMonth()];
  const date = now.getDate();
  const year = now.getFullYear();
  document.getElementById('dateline').textContent = `${day}, ${month} ${date}, ${year}`;
}

tick();
setInterval(tick, 1000);
</script>
</body>
</html>
